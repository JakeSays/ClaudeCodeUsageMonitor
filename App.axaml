<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClaudeUsageMonitor.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://ClaudeUsageMonitor/Assets/icon.ico"
                      ToolTipText="Claude Code Usage Monitor"
                      Clicked="OnTrayIconClicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Minimize to tray"
                                        ToggleType="CheckBox"
                                        Click="OnMinimizeToTrayMenuClicked"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Quit" Click="OnQuitMenuClicked"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>